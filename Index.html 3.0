                        <span class="font-serif italic font-normal text-5xl md:text-6xl lg:text-7xl">my room</span>
                    </h1>
                    <p class="text-lg md:text-xl text-navy/80 max-w-md font-sans leading-relaxed">
                        I'm Nicole Mak, a marketing creative crafting stories that feel like home 🌙. Pull up a chair, turn on the desk lamp, and let's flip through my archive.
                    </p>
                    <div class="flex flex-wrap items-center gap-6 pt-6">
                        <a href="https://www.linkedin.com/in/cheukyingmaknicole" target="_blank" rel="noopener" class="bg-navy text-butter px-6 py-3 rounded-full font-mono text-xs uppercase tracking-widest font-bold hover:opacity-90 transition-opacity whitespace-nowrap">Get to know me</a>
                        <a href="mailto:cymnicole65@gmail.com" class="font-mono text-xs uppercase tracking-[0.2em] font-bold text-navy border-b border-navy pb-1 hover:opacity-70 transition-opacity whitespace-nowrap">Say hello ↗</a>
                    </div>
                </div>

                <!-- Right: Desk Lamp + Music Player -->
                <div class="relative w-full h-[350px] lg:h-full flex flex-col justify-end items-center lg:items-end pb-8">
                    <!-- Desk surface -->
                    <div class="absolute bottom-0 right-[-100px] w-[150%] h-3 bg-navy/10 rounded-l-full transition-colors duration-1000 dark-desk-surface z-0"></div>

                    <!-- Interactive Desk Lamp -->
                    <div id="desk-lamp" class="relative z-10 flex flex-col items-center cursor-pointer group lg:mr-20 transform transition-transform hover:-translate-y-1" title="Click to toggle lights">
                        <!-- Light beam (dark mode only) -->
                        <div class="lamp-beam absolute top-[70px] w-[300px] h-[350px] bg-gradient-to-b from-[#FFFDD0]/60 via-[#FFFDD0]/10 to-transparent origin-top z-0 transition-opacity duration-1000 pointer-events-none" style="clip-path: polygon(30% 0, 70% 0, 100% 100%, 0 100%);"></div>
                        <!-- Shade -->
                        <div class="lamp-part w-32 h-16 bg-navy rounded-t-[60px] relative z-20 transition-colors duration-700 shadow-2xl flex justify-center border border-transparent">
                            <div class="absolute -top-2 w-4 h-2 bg-navy rounded-t-full lamp-part"></div>
                        </div>
                        <!-- Bulb underside -->
                        <div class="bulb-glow w-28 h-6 bg-gray-200 rounded-b-[40px] relative z-10 -mt-1 transition-all duration-700 border-x border-b border-navy/10"></div>
                        <!-- Stem + pull chain -->
                        <div class="lamp-part w-4 h-36 bg-navy relative z-0 -mt-2 transition-colors duration-700 flex justify-center">
                            <div class="absolute top-4 right-[-24px] w-[2px] h-16 bg-navy/30 origin-top transition-transform duration-300 group-hover:scale-y-110 chain-part flex flex-col justify-end items-center">
                                <div class="w-3 h-3 rounded-full bg-navy/50 chain-ball absolute -bottom-1"></div>
                            </div>
                        </div>
                        <!-- Base -->
                        <div class="lamp-part w-28 h-6 bg-navy rounded-t-2xl relative z-20 transition-colors duration-700 border border-transparent"></div>
                    </div>

                    <!-- Mini-Disc Music Player -->
                    <div id="mini-disc-player" class="absolute bottom-6 left-0 lg:left-12 z-30 group flex items-center gap-4 animate-float cursor-pointer">
                        <!-- Tooltip label -->
                        <div class="bg-white/80 backdrop-blur-sm border border-navy/5 px-4 py-2 rounded-full shadow-lg opacity-0 group-hover:opacity-100 transition-all translate-x-4 group-hover:translate-x-0 pointer-events-none flex flex-col items-end">
                            <span class="font-mono text-[9px] uppercase tracking-widest text-navy/50 mb-0.5">Now Playing</span>
