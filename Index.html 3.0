    <!-- ══════════════════════════════════════════
         JAVASCRIPT
    ══════════════════════════════════════════ -->
    <script>
        // ── Light Toggle ──────────────────────────────────────────────
        function toggleLights() {
            document.body.classList.toggle('lights-off');
            if (document.body.classList.contains('lights-off')) {
                createMoonDust(window.innerWidth - 100, 100);
            }
        }

        document.getElementById('light-switch').addEventListener('click', toggleLights);
        document.getElementById('desk-lamp').addEventListener('click', function() {
            this.classList.add('pull-active');
            setTimeout(() => this.classList.remove('pull-active'), 250);
            toggleLights();
        });

        // ── Music Player ──────────────────────────────────────────────
        const disc      = document.getElementById('vinyl-disc');
        const playIcon  = document.getElementById('play-icon');
        const pauseIcon = document.getElementById('pause-icon');
        const audio     = document.getElementById('bg-audio');
        let isPlaying   = false;

        disc.addEventListener('click', () => {
            if (isPlaying) {
                audio.pause();
                disc.classList.remove('playing');
                playIcon.classList.remove('hidden');
                pauseIcon.classList.add('hidden');
            } else {
                audio.play();
                disc.classList.add('playing');
                playIcon.classList.add('hidden');
                pauseIcon.classList.remove('hidden');
            }
            isPlaying = !isPlaying;
        });

        // ── Moon Dust Burst ───────────────────────────────────────────
        function createMoonDust(x, y) {
            for (let i = 0; i < 15; i++) {
                const dust = document.createElement('div');
                dust.className = 'absolute w-2 h-2 rounded-full bg-butter/40 pointer-events-none z-50';
                const sx = x + (Math.random() * 40 - 20);
                const sy = y + (Math.random() * 40 - 20);
                dust.style.cssText = `left:${sx}px;top:${sy}px;transform:scale(${Math.random()*0.5+0.5});transition:all ${Math.random()*1+0.5}s ease-out;`;
                document.body.appendChild(dust);
                setTimeout(() => {
                    dust.style.transform = `translate(${Math.random()*60-30}px,${Math.random()*-60-20}px) scale(0)`;
                    dust.style.opacity = '0';
                }, 10);
                setTimeout(() => dust.remove(), 1500);
            }
        }

        // ── Mouse Trail ───────────────────────────────────────────────
        let lastParticleTime = 0;
        document.addEventListener('mousemove', (e) => {
            const now = Date.now();
            if (now - lastParticleTime < 40) return;
            lastParticleTime = now;

            const isDark = document.body.classList.contains('lights-off');
            const particle = document.createElement('div');
            const size = Math.random() * 4 + 2;
            const offsetX = (Math.random() - 0.5) * 15;
            const offsetY = (Math.random() - 0.5) * 15;

            particle.className = 'trail-particle';
            particle.style.width  = `${size}px`;
            particle.style.height = `${size}px`;
            particle.style.left   = `${e.clientX + offsetX + 6}px`;
            particle.style.top    = `${e.clientY + offsetY + 12}px`;

            if (isDark) {
                particle.style.backgroundColor = 'rgba(255,255,255,0.9)';
                particle.style.boxShadow = '0 0 6px rgba(255,255,255,0.6)';
            } else {
                particle.style.backgroundColor = 'rgba(255,215,0,0.85)';
                particle.style.boxShadow = '0 0 4px rgba(255,200,0,0.5)';
            }

            document.body.appendChild(particle);
            particle.getBoundingClientRect(); // force reflow
            particle.style.transform = `translate(${(Math.random()-0.5)*40}px,${Math.random()*30+10}px) scale(0)`;
            particle.style.opacity = '0';
            setTimeout(() => particle.remove(), 600);
        });

        // ── Polaroid Flip ─────────────────────────────────────────────
        document.querySelectorAll('.project-card-container').forEach(card => {
            card.addEventListener('click', function(e) {
                if (e.target.closest('.view-details-btn')) return;
                document.querySelectorAll('.project-card-container').forEach(c => {
                    if (c !== this) c.classList.remove('flipped');
                });
                this.classList.toggle('flipped');
            });
        });

        // ── Filter Logic ──────────────────────────────────────────────
        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                const filter = btn.dataset.filter;
                document.querySelectorAll('.project-card-container').forEach(project => {
                    if (filter === 'all' || project.dataset.category === filter) {
                        project.style.display = 'block';
                        setTimeout(() => {
                            project.style.opacity = '1';
                            project.style.transform = 'scale(1)';
                        }, 50);
                    } else {
                        project.style.opacity = '0';
                        project.style.transform = 'scale(0.95)';
                        setTimeout(() => { project.style.display = 'none'; }, 400);
                    }
                });
            });
        });

        // ── Project Overlay ───────────────────────────────────────────
        const overlay  = document.getElementById('project-overlay');
        const closeBtn = document.getElementById('close-project');

        document.querySelectorAll('.view-details-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                const d = btn.dataset;
                document.getElementById('overlay-title').textContent       = d.title;
                document.getElementById('overlay-description').textContent = d.desc;
                document.getElementById('overlay-role').textContent        = d.role;
                document.getElementById('overlay-category').textContent    = d.tag;
                
                const singleMedia = document.getElementById('single-media');
                const dualMedia = document.getElementById('dual-media');
                const imgEl = document.getElementById('overlay-img');
                const videoEl = document.getElementById('overlay-video');
                const imgLeft = document.getElementById('overlay-img-left');
                const imgRight = document.getElementById('overlay-img-right');
                
                // Check if this is a dual-image project
                if (d.imageSecondary) {
                    singleMedia.classList.add('hidden');
                    dualMedia.classList.remove('hidden');
                    imgLeft.src = d.image;
                    imgRight.src = d.imageSecondary;
                } else if (d.video) {
                    dualMedia.classList.add('hidden');
                    singleMedia.classList.remove('hidden');
                    imgEl.classList.add('hidden');
                    videoEl.classList.remove('hidden');
                    videoEl.querySelector('source').src = d.video;
                    videoEl.load();
                } else {
                    dualMedia.classList.add('hidden');
                    singleMedia.classList.remove('hidden');
                    videoEl.classList.add('hidden');
                    imgEl.classList.remove('hidden');
                    imgEl.src = d.image;
                }
                
                const launchBtn = document.getElementById('overlay-launch-btn');
                if (d.link) {
                    launchBtn.onclick = () => window.open(d.link, '_blank');
                    launchBtn.style.cursor = 'pointer';
                } else {
                    launchBtn.onclick = null;
                    launchBtn.style.cursor = 'default';
                }
                
                overlay.classList.add('active');
                document.body.style.overflow = 'hidden';
            });
        });

        closeBtn.addEventListener('click', () => {
            overlay.classList.remove('active');
            document.body.style.overflow = '';
        });

        // Close overlay on backdrop click
        overlay.addEventListener('click', (e) => {
            if (e.target === overlay) {
                overlay.classList.remove('active');
                document.body.style.overflow = '';
            }
        });

        // Close overlay on Escape key
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && overlay.classList.contains('active')) {
                overlay.classList.remove('active');
                document.body.style.overflow = '';
            }
        });

        // ── Guestbook Form ────────────────────────────────────────────
        const guestbookForm = document.getElementById('guestbook-form');
        const formStatus    = document.getElementById('form-status');
        const inputs        = guestbookForm.querySelectorAll('input, textarea');

        inputs.forEach(input => {
            input.addEventListener('input', () => {
                const tooltip = input.parentElement.querySelector('.validation-tooltip');
                if (tooltip) {
                    tooltip.classList.remove('show');
                    setTimeout(() => tooltip.remove(), 300);
                }
                input.classList.remove('has-error');
            });
        });

        guestbookForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            guestbookForm.querySelectorAll('.validation-tooltip').forEach(el => el.remove());
            inputs.forEach(input => input.classList.remove('has-error'));

            let isValid = true;
            let firstInvalid = null;

            inputs.forEach(input => {
                if (!input.validity.valid) {
                    isValid = false;
                    if (!firstInvalid) firstInvalid = input;
                    input.classList.add('has-error');

                    const tooltip = document.createElement('div');
                    tooltip.className = 'validation-tooltip';
                    if (input.validity.valueMissing) {
                        tooltip.innerHTML = "Oops! Don't forget this part ✍️";
                    } else if (input.validity.typeMismatch && input.type === 'email') {
                        tooltip.innerHTML = "Hmm, doesn't look like an email 💌";
                    } else {
                        tooltip.innerHTML = "Please check this field ✨";
                    }
                    input.parentElement.appendChild(tooltip);
                    requestAnimationFrame(() => tooltip.classList.add('show'));
                }
            });

            if (!isValid) { firstInvalid.focus(); return; }

            const submitBtn   = guestbookForm.querySelector('button[type="submit"]');
            const originalTxt = submitBtn.innerHTML;
            submitBtn.innerHTML  = 'Sending... 🕊️';
            submitBtn.disabled   = true;

            try {
                const response = await fetch('https://formspree.io/f/xyknrnbw', {
                    method: 'POST',
                    body: new FormData(guestbookForm),
                    headers: { 'Accept': 'application/json' }
                });
                if (response.ok) {
                    formStatus.textContent = "Thanks for leaving a note! 💌";
                    formStatus.classList.remove('hidden', 'text-error');
                    guestbookForm.reset();
                } else {
                    formStatus.textContent = "Oops! There was a problem submitting your note.";
                    formStatus.classList.remove('hidden');
                    formStatus.classList.add('text-error');
                }
            } catch {
                formStatus.textContent = "Oops! There was a problem submitting your note.";
                formStatus.classList.remove('hidden');
                formStatus.classList.add('text-error');
            } finally {
                submitBtn.innerHTML = originalTxt;
                submitBtn.disabled  = false;
                setTimeout(() => formStatus.classList.add('hidden'), 5000);
            }
        });

        // ── Scroll Reveal ─────────────────────────────────────────────
        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    revealObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

           // ── Active Nav Highlight ──────────────────────────────────
        const navLinks = document.querySelectorAll('nav a.nav-link');
        const sections = document.querySelectorAll('[data-nav-section]');

        const navObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const currentId = entry.target.getAttribute('data-nav-section');
                    navLinks.forEach(link => {
                        const icon = link.querySelector('.nav-icon');
                        const href = link.getAttribute('href').substring(1); // remove #
                        if (href === currentId) {
                            icon.classList.add('active-nav');
                        } else {
                            icon.classList.remove('active-nav');
                        }
                    });
                }
            });
        }, { threshold: 0.3 });

        sections.forEach(section => {
            navObserver.observe(section);
        });

        // ── Explicit Navigation Click Handlers ─────────────────────
        document.querySelectorAll('nav a.nav-link').forEach(link => {
            link.addEventListener('click', function(e) {
                e.preventDefault();
                const targetId = this.getAttribute('href').substring(1); // remove #
                const targetElement = document.getElementById(targetId);
                if (targetElement) {
                    targetElement.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });
    </script>
</body>
</html>
